RewriteEngine On

# Rutas SEO amigables
RewriteRule ^servicios/?$ servicios.php [L,NC]
RewriteRule ^contacto/?$ contacto.php [L,NC]

# Bloquear acceso directo a carpetas sensibles
RewriteRule ^(config|database|includes)/ - [F,L]

# No listar directorios
Options -Indexes

# Bloquear ejecución de PHP dentro de uploads
<IfModule mod_php.c>
    <Directory "uploads">
        php_flag engine off
    </Directory>
</IfModule>
